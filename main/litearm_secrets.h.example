#pragma once

/* ============================================================================
 * WiFi 配置
 * ============================================================================ */

/* 当前使用的 WiFi (可通过飞书修改) */
#define LITEARM_SECRET_WIFI_SSID       "你的WiFi名称"
#define LITEARM_SECRET_WIFI_PASS       "你的WiFi密码"

/* 初始 WiFi (可通过物理按钮恢复) */
#define LITEARM_INITIAL_WIFI_SSID      "初始WiFi名称"
#define LITEARM_INITIAL_WIFI_PASS      "初始WiFi密码"

/* ============================================================================
 * 飞书应用配置
 * ============================================================================ */
#define LITEARM_SECRET_FEISHU_APP_ID   "cli_xxxxxxxxxxxx"
#define LITEARM_SECRET_FEISHU_APP_SECRET "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

/* ============================================================================
 * HTTP 代理 (可选)
 * ============================================================================ */
#define LITEARM_SECRET_PROXY_HOST      ""
#define LITEARM_SECRET_PROXY_PORT      ""
